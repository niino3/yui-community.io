# フロントエンド用
# Vercel では Environment Variables で設定
VITE_API_URL=https://yui-communityio-production.up.railway.app

# ネットワーク: "polygon"（本番）または未設定（テストネット Amoy）
# VITE_NETWORK=polygon

# 本番デプロイ後にコントラクトアドレスを設定
# VITE_YUITOKEN_ADDRESS=0x...
# VITE_SBT_ADDRESS=0x...

# 本番用 RPC URL（デフォルト: https://polygon-rpc.com）
# VITE_POLYGON_RPC_URL=https://polygon-rpc.com
